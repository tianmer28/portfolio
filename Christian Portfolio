<title>Christian V. Mercado — Freelance Automation Builder</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#ffffff;--bg2:#f7f7f5;--bg3:#f0f0ec;
  --text:#1a1a1a;--text2:#555;--text3:#888;
  --border:#e2e2de;--border2:#ccc;
  --accent:#1a1a1a;--radius:10px;--radius-lg:14px;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6}
a{color:inherit;text-decoration:none}

/* NAV */
nav{display:flex;justify-content:space-between;align-items:center;padding:1.1rem 2rem;border-bottom:0.5px solid var(--border);position:sticky;top:0;background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);z-index:100}
.nav-logo{font-size:15px;font-weight:600;letter-spacing:-.3px;cursor:pointer}
.nav-links{display:flex;gap:1.5rem}
.nav-links a{font-size:13px;color:var(--text2);cursor:pointer;transition:color .15s}
.nav-links a:hover{color:var(--text)}

/* PAGES */
.page{display:none}.page.active{display:block}

/* HERO */
.hero{padding:5rem 2rem 4rem;border-bottom:0.5px solid var(--border)}
.hero-tag{display:inline-block;font-size:11px;font-weight:500;padding:4px 12px;border-radius:20px;background:var(--bg2);color:var(--text2);border:0.5px solid var(--border);margin-bottom:1.5rem;letter-spacing:.6px;text-transform:uppercase}
.hero h1{font-size:clamp(32px,5vw,48px);font-weight:600;line-height:1.12;letter-spacing:-1.5px;margin-bottom:1rem}
.hero h1 span{color:var(--text3)}
.hero p{font-size:15px;color:var(--text2);line-height:1.75;max-width:480px;margin-bottom:2rem}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap}
.btn-p{background:var(--text);color:#fff;font-size:13px;font-weight:500;padding:10px 22px;border-radius:var(--radius);border:none;cursor:pointer;transition:opacity .15s}
.btn-p:hover{opacity:.85}
.btn-s{background:transparent;color:var(--text);font-size:13px;padding:10px 22px;border-radius:var(--radius);border:0.5px solid var(--border2);cursor:pointer;transition:background .15s}
.btn-s:hover{background:var(--bg2)}

/* SECTIONS */
section{padding:3.5rem 2rem;border-bottom:0.5px solid var(--border)}
.section-label{font-size:11px;text-transform:uppercase;letter-spacing:.8px;font-weight:500;color:var(--text3);margin-bottom:1.75rem}

/* PROJECT CARDS */
.project-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}
.project-card{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;cursor:pointer;transition:border-color .15s,box-shadow .15s}
.project-card:hover{border-color:var(--border2);box-shadow:0 4px 20px rgba(0,0,0,.06)}
.project-thumb{width:100%;height:140px;object-fit:cover;border-radius:var(--radius);margin-bottom:1rem;border:0.5px solid var(--border)}
.project-title{font-size:14px;font-weight:600;margin-bottom:6px}
.project-desc{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:1rem}
.project-tags{display:flex;flex-wrap:wrap;gap:5px}
.ptag{font-size:11px;padding:3px 9px;border-radius:20px;background:var(--bg2);color:var(--text2);border:0.5px solid var(--border)}
.view-more{font-size:12px;color:var(--text3);margin-top:10px;display:inline-block}

/* SKILLS */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(158px,1fr));gap:10px}
.skill-item{background:var(--bg2);border-radius:var(--radius);padding:1rem}
.skill-name{font-size:13px;font-weight:500;margin-bottom:8px}
.skill-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.skill-fill{height:100%;background:var(--text);border-radius:2px}
.skill-level{font-size:11px;color:var(--text3);margin-top:6px}

/* ABOUT */
.about-layout{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.about-text p{font-size:14px;color:var(--text2);line-height:1.8;margin-bottom:1rem}
.stat-row{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.stat-card{background:var(--bg2);border-radius:var(--radius);padding:1rem;text-align:center}
.stat-num{font-size:26px;font-weight:600}
.stat-lbl{font-size:12px;color:var(--text2);margin-top:4px}

/* CONTACT */
.contact-layout{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.contact-info p{font-size:14px;color:var(--text2);line-height:1.8;margin-bottom:1.5rem}
.contact-links{display:flex;flex-direction:column;gap:10px}
.contact-link{font-size:13px;color:var(--text2);display:flex;align-items:center;gap:8px;word-break:break-all}
.contact-form{display:flex;flex-direction:column;gap:10px}
.contact-form input,.contact-form textarea{width:100%;font-size:13px;padding:10px 12px;border-radius:var(--radius);border:0.5px solid var(--border2);background:var(--bg2);color:var(--text);font-family:inherit;resize:none;outline:none;transition:border-color .15s}
.contact-form input:focus,.contact-form textarea:focus{border-color:var(--text)}
.contact-form textarea{height:100px}

/* DETAIL PAGE */
.detail-hero{padding:3rem 2rem 2rem;border-bottom:0.5px solid var(--border)}
.btn-back{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text2);background:transparent;border:0.5px solid var(--border);padding:7px 14px;border-radius:var(--radius);cursor:pointer;margin-bottom:2rem;transition:border-color .15s}
.btn-back:hover{border-color:var(--border2);color:var(--text)}
.detail-icon{width:52px;height:52px;border-radius:var(--radius-lg);background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:1.25rem;border:0.5px solid var(--border)}
.detail-title{font-size:26px;font-weight:600;letter-spacing:-.5px;margin-bottom:.5rem}
.detail-subtitle{font-size:14px;color:var(--text2);margin-bottom:1.25rem}
.detail-body{padding:2rem}
.detail-grid{display:grid;grid-template-columns:2fr 1fr;gap:2.5rem;align-items:start}
.detail-section{margin-bottom:2rem}
.detail-section h3{font-size:11px;text-transform:uppercase;letter-spacing:.8px;font-weight:500;color:var(--text3);margin-bottom:1rem;padding-bottom:.4rem;border-bottom:0.5px solid var(--border)}
.detail-section p{font-size:14px;color:var(--text2);line-height:1.8;margin-bottom:.75rem}
.flow-step{display:flex;align-items:flex-start;gap:12px;margin-bottom:10px}
.step-num{min-width:24px;height:24px;border-radius:50%;background:var(--bg2);border:0.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--text2);margin-top:1px;flex-shrink:0}
.step-text{font-size:13px;color:var(--text2);line-height:1.7}
.step-text strong{color:var(--text);font-weight:500}
.sidebar-card{background:var(--bg2);border-radius:var(--radius-lg);padding:1.25rem;margin-bottom:1rem}
.sidebar-card h3{font-size:11px;text-transform:uppercase;letter-spacing:.8px;font-weight:500;color:var(--text3);margin-bottom:.75rem}
.sidebar-card p{font-size:13px;color:var(--text2)}
.outcome-item{display:flex;align-items:flex-start;gap:8px;margin-bottom:8px;font-size:13px;color:var(--text2);line-height:1.6}
.outcome-dot{min-width:5px;height:5px;border-radius:50%;background:var(--text3);margin-top:7px;flex-shrink:0}
.link-btn{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);padding:6px 12px;border-radius:var(--radius);border:0.5px solid var(--border);text-decoration:none;margin-top:4px;transition:border-color .15s}
.link-btn:hover{border-color:var(--border2);color:var(--text)}

/* SCREENSHOTS */
.screenshots-section{margin-bottom:2rem}
.screenshots-section h3{font-size:11px;text-transform:uppercase;letter-spacing:.8px;font-weight:500;color:var(--text3);margin-bottom:1rem;padding-bottom:.4rem;border-bottom:0.5px solid var(--border)}
.ss-grid-1{display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:10px}
.ss-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.ss-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.screenshot-wrap{border-radius:var(--radius);overflow:hidden;border:0.5px solid var(--border);background:var(--bg2);cursor:pointer}
.screenshot-wrap img{width:100%;display:block;object-fit:cover;transition:opacity .15s}
.screenshot-wrap:hover img{opacity:.85}
.screenshot-caption{font-size:11px;color:var(--text3);padding:6px 10px;line-height:1.4}

/* LIGHTBOX */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:999;align-items:center;justify-content:center}
.lightbox.open{display:flex}
.lightbox img{max-width:92%;max-height:88vh;border-radius:var(--radius-lg);object-fit:contain}
.lb-close{position:fixed;top:18px;right:22px;font-size:26px;color:#fff;cursor:pointer;background:none;border:none;opacity:.8;line-height:1}
.lb-close:hover{opacity:1}

/* FOOTER */
footer{padding:2rem;text-align:center;font-size:12px;color:var(--text3);border-top:0.5px solid var(--border)}

/* RESPONSIVE */
@media(max-width:600px){
  .about-layout,.contact-layout,.detail-grid{grid-template-columns:1fr}
  .ss-grid-2,.ss-grid-3{grid-template-columns:1fr}
  .hero h1{font-size:28px}
  .detail-title{font-size:20px}
  nav{padding:.9rem 1rem}
  section,.hero,.detail-hero,.detail-body{padding-left:1rem;padding-right:1rem}
}
</style>
